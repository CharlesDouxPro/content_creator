# ============================================================================
# content_creator — modèle de configuration runtime
# Copier en `.env` puis ajuster. Chargé par content_creator/config/config.py.
# ============================================================================

# --- Backend vidéo : DeepInfra (hébergé) vs serveur LTX-2.3 local ---
# 'true' => router ce type de plan vers le serveur LTX local. Défaut: DeepInfra.
USE_LTX_BROLL=false        # b-roll      -> LTX /generate (i2v) au lieu de Wan
USE_LTX_LIPSYNC=false      # tête parlante -> LTX /generate (i2v) au lieu de Pruna

LTX_SERVER_URL=http://localhost:8000
LTX_TIMEOUT=1800
LTX_WIDTH=720
LTX_HEIGHT=1280
LTX_FRAME_RATE=24
LTX_HDR=false

# --- DeepInfra ---
DEEPINFRA_API_KEY=
DEEPINFRA_BASE_URL=https://api.deepinfra.com/v1/openai
# Tokens DeepInfra par "provider" (cf. channels.py : arlq_deepinfra_config / charles_deepinfra_config)
ARLQ_DEEPINFRA_TOKEN=
CHARLES_DEEPINFRA_TOKEN=

# --- Google (TTS + Custom Search) ---
GOOGLE_TTS_API_KEY=
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# --- Creatomate (sous-titres) ---
CREATOMATE_API_KEY=
CREATOMATE_SUBTITLE_TEMPLATE_ID=

# --- Veo3 / Runway / Pexels ---
VEO3_API_KEY=
RUNWAY_API_KEY=
PEXELS_API_KEY=
